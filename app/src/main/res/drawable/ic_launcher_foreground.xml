<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        Indian Rupee sign ₹
        Centered in adaptive-icon safe zone (center 72×72 area).
        Structure:
          – top horizontal bar
          – second horizontal bar
          – left curve connecting the two bars
          – diagonal stroke from second bar down-right
    -->

    <!-- Top horizontal bar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,35 L70,35 A2,2 0 0 1 70,39 L38,39 A2,2 0 0 1 38,35 Z" />

    <!-- Second horizontal bar -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M38,45 L70,45 A2,2 0 0 1 70,49 L38,49 A2,2 0 0 1 38,45 Z" />

    <!-- Left vertical + curve (the bump that makes ₹ unique) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M44,35 L48,35 C56,35 56,49 48,49 L44,49 L44,45 C50,45 50,39 44,39 Z" />

    <!-- Diagonal stroke going down-right -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M44,49 L48,49 L64,73 L60,77 Z" />

</vector>